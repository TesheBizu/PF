PORT=5000
MONGO_URI=mongodb+srv://<db_user>:<ADMIN_PASSWORD>@cluster.mongodb.net/cluster?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
NODE_ENV=development
ADMIN_EMAIL=teshelin7@gmail.com
ADMIN_PASSWORD=Admin@123

# Comma-separated frontend origins (portfolio + admin) — no trailing slashes
# Example production:
# CLIENT_URL=https://your-portfolio.vercel.app,https://pf-admin-port.vercel.app
CLIENT_URL=http://localhost:5173,http://localhost:5174

# Google OAuth (admin app only)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Cloudinary Settings
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
